      "updated": 1783437418427,
      "link": null,
      "locked": false,
      "text": "I import passlib in hash_password.py.\npyproject.toml lists \"pwdlib[argon2]\", \nwhich is incorrect\nIt should be: passlib[argon2]",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "32znz6__sKYDXF0a4zydl",
      "originalText": "I import passlib in hash_password.py.\npyproject.toml lists \"pwdlib[argon2]\", \nwhich is incorrect\nIt should be: passlib[argon2]",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
