    {
      "id": "7EBKOO_ICUKXd7QiTUYQC",
      "type": "text",
      "x": 330.6147512182059,
      "y": 135.01075499672484,
      "width": 383.7396240234375,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
