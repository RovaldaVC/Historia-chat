      "text": "Problem:\ncrud_login() doesn't\ncheck if user.active\n== True\nImpact:\nDeactivated/banned\nusers can still\nauthenticate",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "z0864RAwVc1aye5vsjK5X",
      "originalText": "Problem: crud_login() doesn't check if user.active == True\nImpact: Deactivated/banned users can still authenticate",
      "autoResize": true,
      "lineHeight": 1.35
    },
