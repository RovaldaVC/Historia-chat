      "updated": 1783311685298,
      "link": null,
      "locked": false,
      "text": "Problem: active: bool is\na required field in\nUserCreate without a\ndefault, allowing\nclients to set\nthemselves as active\nImpact: Users can self-\nactivate before email\nverification/admin\napproval",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "ZUFCzdYPAOcYwRH-Wd9o_",
      "originalText": "Problem: active: bool is a required field in UserCreate without a default, allowing clients to set themselves as active\nImpact: Users can self-activate before email verification/admin approval",
      "autoResize": true,
      "lineHeight": 1.35
    },
