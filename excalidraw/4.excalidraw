    {
      "id": "N1cvuEhurBgbAcLgm-b-c",
      "type": "text",
      "x": 521.1211714971681,
      "y": 380.7881135486416,
      "width": 291.7196960449219,
      "height": 297,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
