    {
      "id": "7EBKOO_ICUKXd7QiTUYQC",
      "type": "text",
      "x": 829.4862380254885,
      "y": 55.788113548641604,
      "width": 383.73956298828125,
      "height": 270,
      "angle": 0,
      "strokeColor": "#e03131",
