      "updated": 1783306838322,
      "link": null,
      "locked": false,
      "text": "The password field is\nlimited to 100\ncharacters, but Argon2\nhashes can exceed this\nlength (typically 96+\ncharacters)\nImpact: Database\nconstraint violation\nwhen storing hashed\npasswords",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "oadXdRE8uHgFMYvHedh1h",
      "originalText": "The password field is limited to 100 characters, but Argon2 hashes can exceed this length (typically 96+ characters)\nImpact: Database constraint violation when storing hashed passwords",
      "autoResize": true,
      "lineHeight": 1.35
    },
