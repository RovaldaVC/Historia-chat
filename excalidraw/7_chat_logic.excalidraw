      "index": "a3G",
      "roundness": null,
      "seed": 2106361647,
      "version": 910,
      "versionNonce": 542223983,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783904421064,
      "link": null,
      "locked": false,
      "text": "- it has only one field inside\nit called name.\n- this asks user for a name\nto insert as the chat's\nname.\n- later we need to save\ncontact's name or number\nfor private chat!",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- it has only one field inside it called name.\n- this asks user for a name to insert as the chat's name.\n- later we need to save contact's name or number for private chat!",
      "autoResize": false,
      "lineHeight": 1.35
    },
