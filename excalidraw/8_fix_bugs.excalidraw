    {
      "id": "Z8XkYJ33z0mCcmun8OxIR",
      "type": "text",
      "x": 799.4516296386719,
      "y": 684.1,
      "width": 372.09674072265625,
      "height": 172.8,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
