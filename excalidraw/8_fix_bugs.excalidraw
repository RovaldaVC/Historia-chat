      "updated": 1784352200644,
      "link": null,
      "locked": false,
      "text": "another one of my friends said that my code\ninside verify_session has problem! \nif 1000 users are online we have to run bcrypt\n1000 times which is huge! instead of that filter\nthe query based on hash token!",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "lxWqDX6583pEeIVCCQYvk",
      "originalText": "another one of my friends said that my code inside verify_session has problem! \nif 1000 users are online we have to run bcrypt  1000 times which is huge! instead of that filter the query based on hash token!",
      "autoResize": true,
      "lineHeight": 1.35
    },
