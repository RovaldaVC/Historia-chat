    {
      "id": "cB4PDZkl_GWSOgdTfJr0P",
      "type": "text",
      "x": 768.4642944335938,
      "y": 689.95,
      "width": 588.3214111328125,
      "height": 129.60000000000002,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aaV",
      "roundness": null,
      "seed": 1630189423,
      "version": 40,
      "versionNonce": 626296257,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784368173037,
      "link": null,
      "locked": false,
      "text": "The specific dependency in authentication.py is not compatible with a WebSocket\nroute because it expects an HTTP Request:\ndef get_current_user(request: Request, db: Session = Depends(get_db)) -> User:\nA WebSocket connection is not an HTTP Request, so FastAPI cannot supply that\nargument. That is why your app hit the error:\ntypeError: get_current_user() missing 1 required positional argument: 'request'",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "5ov1Rtefrc0mPrmkh3mBp",
      "originalText": "The specific dependency in authentication.py is not compatible with a WebSocket route because it expects an HTTP Request:\ndef get_current_user(request: Request, db: Session = Depends(get_db)) -> User:\nA WebSocket connection is not an HTTP Request, so FastAPI cannot supply that argument. That is why your app hit the error:\ntypeError: get_current_user() missing 1 required positional argument: 'request'",
      "autoResize": true,
      "lineHeight": 1.35
    },
