      "updated": 1784367377054,
      "link": null,
      "locked": false,
      "text": "Line 51 of models.py:\nwhen crud_save_message runs then user_id\nwill be saved as sender_id, but FK is\nchat_participant.\nFK violation!",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "atv_UHx16vhjSVecp2JOT",
      "originalText": "Line 51 of models.py:\nwhen crud_save_message runs then user_id will be saved as sender_id, but FK is chat_participant.\nFK violation!",
      "autoResize": true,
      "lineHeight": 1.35
