      "updated": 1784368165810,
      "link": null,
      "locked": false,
      "text": "Instead of loading all the UserSession for each\nrequest; just create a new table and save\nsession_id and user_id inside it.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "SbgKLg9Zak2Ce8ae75djO",
      "originalText": "Instead of loading all the UserSession for each request; just create a new table and save session_id and user_id inside it.",
      "autoResize": true,
      "lineHeight": 1.35
    },
