    {
      "id": "BEnbMyXG3zLygW1e0uyeb",
      "type": "text",
      "x": -653.7303417185483,
      "y": -213.39629860239535,
      "width": 288.72064208984375,
      "height": 151.20000000000002,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aI",
      "roundness": null,
      "seed": 1527554059,
      "version": 398,
      "versionNonce": 13778373,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782922810852,
      "link": null,
      "locked": false,
      "text": "Storing session tokens in the database\nwithout hashing them is just like storing\npasswords in plain text. If an attacker\ngains access to these session tokens,\nthey'll have access to every single\naccount. So, make sure to hash them in\nthe database.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "XxcqC2uLZ4y-Q67w6hsdA",
      "originalText": "Storing session tokens in the database without hashing them is just like storing passwords in plain text. If an attacker gains access to these session tokens, they'll have access to every single account. So, make sure to hash them in the database.",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "-L6lOlVG0YGGHk6z1Fj4m",
      "type": "rectangle",
      "x": -256.53261135058506,
      "y": -325.3487566623443,
      "width": 306.5259691044415,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aK",
      "roundness": null,
      "seed": 2073064133,
      "version": 1455,
      "versionNonce": 1225146373,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "DYHVZBjnakbbihvFtS5kr"
        },
        {
          "id": "UypX2Qg-wNe0hw1dJ4j4q",
