    {
      "id": "BEnbMyXG3zLygW1e0uyeb",
      "type": "text",
      "x": -59.99333953857422,
      "y": -161.94017857142845,
      "width": 249.74449157714844,
      "height": 172.8,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aI",
      "roundness": null,
      "seed": 1527554059,
      "version": 113,
      "versionNonce": 406695339,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782919591093,
      "link": null,
      "locked": false,
      "text": "Storing session tokens in the\ndatabase without hashing them is\njust like storing passwords in plain\ntext. If an attacker gains access to\nthese session tokens, they'll have\naccess to every single account. So,\nmake sure to hash them in the\ndatabase.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "XxcqC2uLZ4y-Q67w6hsdA",
      "originalText": "Storing session tokens in the database without hashing them is just like storing passwords in plain text. If an attacker gains access to these session tokens, they'll have access to every single account. So, make sure to hash them in the database.",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "-L6lOlVG0YGGHk6z1Fj4m",
      "type": "rectangle",
      "x": 281.453125,
      "y": -299.20424107142844,
      "width": 262.56250000000006,
      "height": 313,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aK",
      "roundness": null,
      "seed": 2073064133,
      "version": 958,
      "versionNonce": 2096097504,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "DYHVZBjnakbbihvFtS5kr"
        },
        {
          "id": "UypX2Qg-wNe0hw1dJ4j4q",
