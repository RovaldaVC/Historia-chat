      "isDeleted": false,
      "boundElements": [
        {
          "id": "HSmex-fTIY-aYThktJZy7",
          "type": "arrow"
        }
      ],
      "updated": 1782755263532,
      "link": null,
      "locked": false,
      "text": "A Session Table: Add a new model in\nmodels.py to store active sessions\n(linking a unique session ID to a user_id).\n\nCookie Handling: Update your login route to\ngenerate\n a random session ID, save it to the database, \nand send it to the user's browser using\nresponse.set_cookie().\n\nA New Dependency: Create a fresh\nget_current_user function that\n reads the session ID from the cookie and\nfetches the user from the database.",
      "fontSize": 17.009216753650687,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A Session Table: Add a new model in models.py to store active sessions\n(linking a unique session ID to a user_id).\n\nCookie Handling: Update your login route to generate\n a random session ID, save it to the database, \nand send it to the user's browser using response.set_cookie().\n\nA New Dependency: Create a fresh get_current_user function that\n reads the session ID from the cookie and fetches the user from the database.",
      "autoResize": false,
      "lineHeight": 1.35
    },
